# Backend base URL (your deployed parse + export server). MUST be HTTPS in production.
EXPO_PUBLIC_PARSE_API_BASE_URL=https://api.zawmbi.com

# Export endpoints — typically the same host with the path appended.
EXPO_PUBLIC_GOOGLE_EXPORT_URL=https://api.zawmbi.com/exports/google
EXPO_PUBLIC_NOTION_EXPORT_URL=https://api.zawmbi.com/exports/notion

# RevenueCat — required for subscriptions to work in production.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_xxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_xxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
