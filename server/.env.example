PORT=8787
APP_BASE_URL=https://api.zawmbi.com

# OpenAI — required for live syllabus parsing.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Google Calendar OAuth — required for the Google export flow.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.zawmbi.com/oauth/google/callback

# Notion OAuth — required for the Notion export flow.
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=https://api.zawmbi.com/oauth/notion/callback
NOTION_TOKEN=
NOTION_DATABASE_ID=

# CORS allowlist (comma-separated). Leave empty to skip Origin checks
# (safe when only the native app calls the API; tighten if you ever serve a web client).
ALLOWED_ORIGINS=

# Persistent session store path. Use a writable location with restricted permissions.
SESSION_STORE_PATH=./.data/sessions.json

# Rate limit knobs for /parse-syllabus.
PARSE_RATE_MAX=30
PARSE_RATE_WINDOW_MS=60000
